---
const reviewPage = "/review/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      http-equiv="refresh"
      content={`0; url=${reviewPage}`}
    />
    <meta name="robots" content="noindex" />
    <link
      rel="canonical"
      href="https://marcoapex100.github.io/review/"
    />
    <title>Redirecting…</title>

    <script is:inline>
      window.location.replace("/review/");
    </script>
  </head>

  <body>
    <p>
      Redirecting to the
      <a href="/review/">review page</a>.
    </p>
  </body>
</html>