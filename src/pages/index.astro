---
import MainLayout from "../layouts/MainLayout.astro";
import bookCover from "../assets/book-cover.png";
---

<MainLayout title="Marco Apex | The Soul of Speed">

  <section class="hero">

    <div class="container hero-grid">

      <div class="hero-copy">

        <p class="eyebrow">
          THANK YOU FOR READING
        </p>

        <div class="stars" aria-label="Five stars">
          ★★★★★
        </div>

        <h1>
          Help this story reach more Formula One fans.
        </h1>

        <p class="intro">
          Your review of <em>Formula One: The Soul of Speed</em>
          helps other readers discover the design, drama and
          unforgettable stories behind the world’s greatest motorsport.
        </p>

        <a href="/review" class="button">
          Leave a Review
        </a>

        <p class="supporting-text">
          It only takes a moment. Select your Amazon store on the next page.
        </p>

        <div class="secondary-links">
          <a href="#book">About the Book</a>
          <a href="#bonus">Bonus Guide</a>
          <a href="#join">Join The Grid</a>
        </div>

      </div>

      <div class="cover-column">

        <img
          src={bookCover.src}
          alt="Formula One: The Soul of Speed book cover by Marco Apex"
          class="book-cover"
        />

      </div>

    </div>

  </section>

</MainLayout>

<style>

.hero{
  min-height:90vh;
  display:flex;
  align-items:center;
  padding:80px 0;
}

.hero-grid{
  display:grid;
  grid-template-columns:minmax(0,1.2fr) minmax(280px,.8fr);
  gap:80px;
  align-items:center;
}

.hero-copy{
  max-width:760px;
}

.eyebrow{
  color:var(--accent);
  letter-spacing:4px;
  text-transform:uppercase;
  font-size:.85rem;
  font-weight:700;
  margin-bottom:18px;
}

.stars{
  color:var(--accent);
  font-size:1.35rem;
  letter-spacing:7px;
  margin-bottom:25px;
}

h1{
  font-size:clamp(3rem,6vw,5.8rem);
  line-height:1.02;
  max-width:820px;
  margin-bottom:28px;
}

.intro{
  max-width:680px;
  font-size:1.2rem;
  line-height:1.7;
  margin-bottom:35px;
}

.button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:220px;
  padding:17px 30px;
  border-radius:999px;
  font-size:1rem;
  font-weight:700;
  text-decoration:none;
}

.supporting-text{
  margin-top:16px;
  font-size:.95rem;
  opacity:.7;
}

.secondary-links{
  display:flex;
  flex-wrap:wrap;
  gap:24px;
  margin-top:42px;
}

.secondary-links a{
  color:inherit;
  text-decoration:none;
  font-size:.95rem;
  opacity:.72;
  border-bottom:1px solid transparent;
  padding-bottom:3px;
  transition:opacity .2s ease,border-color .2s ease;
}

.secondary-links a:hover{
  opacity:1;
  border-color:var(--accent);
}

.cover-column{
  display:flex;
  justify-content:center;
}

.book-cover{
  display:block;
  width:min(100%,430px);
  height:auto;
  border-radius:6px;
  box-shadow:
    0 30px 80px rgba(0,0,0,.65),
    0 0 40px rgba(196,148,72,.08);
}

@media (max-width:900px){

  .hero{
    padding:60px 0 80px;
  }

  .hero-grid{
    grid-template-columns:1fr;
    gap:55px;
  }

  .hero-copy{
    text-align:center;
    margin:0 auto;
  }

  .intro{
    margin-left:auto;
    margin-right:auto;
  }

  .secondary-links{
    justify-content:center;
  }

  .cover-column{
    order:-1;
  }

  .book-cover{
    width:min(78vw,360px);
  }

}

@media (max-width:560px){

  .hero{
    min-height:auto;
    padding:42px 0 65px;
  }

  .hero-grid{
    gap:38px;
  }

  .eyebrow{
    letter-spacing:3px;
  }

  h1{
    font-size:clamp(2.6rem,13vw,4rem);
  }

  .intro{
    font-size:1.05rem;
  }

  .button{
    width:100%;
  }

  .secondary-links{
    gap:16px 22px;
  }

}

</style>