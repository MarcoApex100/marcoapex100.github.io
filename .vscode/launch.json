:root {
  --bg: #0b0b0c;
  --surface: #141416;
  --text: #ffffff;
  --muted: #a8a8a8;
  --accent: #d61f26;
  --max-width: 1200px;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: Inter, Arial, Helvetica, sans-serif;
  line-height: 1.6;
}

img {
  max-width: 100%;
  display: block;
}

a {
  color: inherit;
  text-decoration: none;
}

.container {
  width: min(var(--max-width), calc(100% - 48px));
  margin-inline: auto;
}

section {
  padding: 100px 0;
}

h1,
h2,
h3 {
  margin: 0;
}

p {
  color: var(--muted);
}

.button {
  display: inline-block;
  padding: 16px 34px;
  background: var(--accent);
  color: white;
  border-radius: 8px;
  font-weight: 600;
  transition: .25s;
}

.button:hover {
  transform: translateY(-2px);
}