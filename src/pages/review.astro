---
import MainLayout from "../layouts/MainLayout.astro";
import bookCover from "../assets/book-cover.png";
---

<MainLayout title="Leave a Review | Formula One: The Soul of Speed">

<div
  class="cover-background cover-background-left"
  style={`background-image: url(${bookCover.src});`}
  aria-hidden="true"
></div>

<div
  class="cover-background cover-background-right"
  style={`background-image: url(${bookCover.src});`}
  aria-hidden="true"
></div>

  <main class="review-page">

    <section class="review-section">

      <p class="eyebrow">
        FORMULA ONE: THE SOUL OF SPEED
      </p>

      <h1>Leave a Review</h1>

      <p class="review-intro">
        Select your Amazon store to leave a review.
      </p>

      <p id="detected-message" class="detected-message"></p>

      <div class="store-buttons">

        <a
          id="uk"
          href="https://www.amazon.co.uk/review/create-review?asin=B0G7KRKL32"
          class="store-button"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>🇬🇧</span>
          Amazon UK
        </a>

        <a
          id="usa"
          href="https://www.amazon.com/review/create-review?asin=B0G7KRKL32"
          class="store-button"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>🇺🇸</span>
          Amazon USA
        </a>

        <a
          id="canada"
          href="https://www.amazon.ca/review/create-review?asin=B0G7KRKL32"
          class="store-button"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>🇨🇦</span>
          Amazon Canada
        </a>

        <a
          id="australia"
          href="https://www.amazon.com.au/review/create-review?asin=B0G776P2HB"
          class="store-button"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>🇦🇺</span>
          Amazon Australia
        </a>

      </div>

      <p class="thank-you">
        Thank you for helping this story reach more Formula One fans.
      </p>

    </section>

    <div class="section-divider"></div>

    <section class="bonus-section">

      <p class="section-label">FREE READER BONUS</p>

      <h2>Collector’s Lap Guide</h2>

      <p>
        Access your complimentary Formula One circuit guide.
      </p>

      <a
  href="/downloads/The_Collectors_Lap_Guide.pdf"
  class="secondary-button"
  target="_blank"
  rel="noopener noreferrer"
>
  Download the Collector's Lap Guide
</a>

    </section>

  </main>

  <script>
    const countryMap = {
      GB: "uk",
      US: "usa",
      CA: "canada",
      AU: "australia"
    };

    const countryNames = {
      GB: "Amazon UK",
      US: "Amazon USA",
      CA: "Amazon Canada",
      AU: "Amazon Australia"
    };

    fetch("https://ipapi.co/json/")
      .then((response) => response.json())
      .then((data) => {
        const country = data.country_code;
        const buttonId = countryMap[country];

        if (!buttonId) return;

        const button = document.getElementById(buttonId);
        const message = document.getElementById("detected-message");

        if (button) {
          button.classList.add("recommended");
        }

        if (message) {
          message.textContent =
            "Recommended for you: " + countryNames[country];
        }
      })
      .catch(() => {
        console.log("Marketplace detection unavailable");
      });
  </script>

</MainLayout>

<style>
.cover-background{
  position:fixed;
  top:0;
  width:min(30vw,420px);
  height:100vh;
  background-position:center;
  background-repeat:no-repeat;
  background-size:cover;
  pointer-events:none;
  z-index:0;
}

.cover-background-right{
  right:0;
  opacity:.16;
  -webkit-mask-image:linear-gradient(
    to right,
    transparent 0%,
    rgba(0,0,0,.25) 28%,
    black 100%
  );
  mask-image:linear-gradient(
    to right,
    transparent 0%,
    rgba(0,0,0,.25) 28%,
    black 100%
  );
}

.cover-background-left{
  left:0;
  opacity:.08;
  transform:scaleX(-1);
  -webkit-mask-image:linear-gradient(
    to left,
    transparent 0%,
    rgba(0,0,0,.25) 28%,
    black 100%
  );
  mask-image:linear-gradient(
    to left,
    transparent 0%,
    rgba(0,0,0,.25) 28%,
    black 100%
  );
}

.review-page{
  position:relative;
  z-index:1;
  width:min(100% - 40px,760px);
  margin:0 auto;
  padding:90px 0;
}

.review-section,
.bonus-section,
.grid-section{
  text-align:center;
}

.eyebrow,
.section-label{
  color:var(--accent);
  font-size:.78rem;
  font-weight:700;
  letter-spacing:3px;
  text-transform:uppercase;
  margin-bottom:18px;
}

h1{
  font-size:clamp(3rem,8vw,5.5rem);
  line-height:1;
  margin:0 0 22px;
}

h2{
  font-size:clamp(2rem,5vw,3.2rem);
  line-height:1.1;
  margin:0 0 18px;
}

.review-intro,
.bonus-section p,
.grid-section p{
  max-width:590px;
  margin:0 auto 30px;
  font-size:1.08rem;
  line-height:1.7;
  opacity:.82;
}

.detected-message{
  min-height:24px;
  margin:0 0 18px;
  color:var(--accent);
  font-size:.95rem;
  font-weight:700;
}

.store-buttons{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:14px;
  max-width:620px;
  margin:0 auto;
}

.store-button{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  min-height:62px;
  padding:15px 20px;
  color:inherit;
  background:rgba(255,255,255,.045);
  border:1px solid rgba(255,255,255,.16);
  border-radius:10px;
  font-weight:700;
  text-decoration:none;
  transition:
    transform .2s ease,
    border-color .2s ease,
    background .2s ease;
}

.store-button:hover{
  transform:translateY(-2px);
  border-color:var(--accent);
  background:rgba(255,255,255,.075);
}

.store-button.recommended{
  border-color:var(--accent);
  box-shadow:0 0 0 1px var(--accent);
}

.store-button.recommended::after{
  content:"Recommended";
  display:inline-block;
  margin-left:5px;
  color:var(--accent);
  font-size:.66rem;
  letter-spacing:1px;
  text-transform:uppercase;
}

.thank-you{
  margin:28px auto 0;
  font-size:.95rem;
  line-height:1.6;
  opacity:.68;
}

.section-divider{
  width:100%;
  height:1px;
  margin:72px 0;
  background:linear-gradient(
    to right,
    transparent,
    rgba(255,255,255,.2),
    transparent
  );
}

.secondary-button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:230px;
  min-height:58px;
  padding:15px 28px;
  color:inherit;
  border:1px solid var(--accent);
  border-radius:999px;
  font-weight:700;
  text-decoration:none;
  transition:
    background .2s ease,
    color .2s ease,
    transform .2s ease;
}

.secondary-button:hover{
  transform:translateY(-2px);
  background:var(--accent);
  color:#111;
}

@media (max-width:700px){

  .cover-background{
    width:100%;
    height:55vh;
    opacity:.08;
    background-position:center top;
    -webkit-mask-image:linear-gradient(
      to bottom,
      black 0%,
      transparent 100%
    );
    mask-image:linear-gradient(
      to bottom,
      black 0%,
      transparent 100%
    );
  }

  .review-page{
    width:min(100% - 28px,760px);
    padding:58px 0 70px;
  }

  .store-buttons{
    grid-template-columns:1fr;
  }

  .section-divider{
    margin:55px 0;
  }

  .store-button.recommended::after{
    display:none;
  }

}

</style>